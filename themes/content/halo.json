    { "name": "Senior Herald of the Covenant",     "canonical": "Marketing Senior Consultant",              "description": "Strategist of campaigns — sounds the call to gather the faithful." },
    { "name": "Herald of the Covenant",            "canonical": "Marketing Consultant",                     "description": "Carries the campaign forward — content, creative, and the daily broadcast." },
    { "name": "Cortana Analyst",                   "canonical": "Business Analyst",                         "description": "Records what is needed and what is promised — translates between mortal Customer and the AI's design." },
