  "roles": [
    { "name": "Chief Science Officer",            "canonical": "Solution Architect",                      "description": "Designs the over-arching mission architecture — surveys the unknown and charts the safest course through it." },
    { "name": "First Officer",                    "canonical": "Project Manager",                         "description": "Runs the duty roster, holds the timeline, and answers to the Captain on mission status." },
    { "name": "Operations Officer",               "canonical": "Salesforce Administrator",                "description": "Steward of ship's systems — keeps records, layouts, and consoles in working order." },
    { "name": "Chief Engineer",                   "canonical": "Salesforce Developer",                    "description": "Forges Apex, LWC, and platform features deep in main engineering." },
    { "name": "Captain of Starfleet Command",     "canonical": "Salesforce Practice Lead - USA",          "description": "Sets standards across the fleet's Salesforce craft and mentors the senior officers." },
    { "name": "Senior Engineering Officer",       "canonical": "Salesforce Senior Consultant - India",    "description": "Veteran of countless deck-12 retrofits — carries discovery and configuration with practiced hand." },
    { "name": "Junior Engineering Officer",       "canonical": "Salesforce Consultant - India",           "description": "Learning the consoles under the Chief's eye — handles configuration and routine builds." },
    { "name": "Chief of Subspace Communications", "canonical": "Integration Technical Architect - USA",   "description": "Architect of the great subspace links between Salesforce and the realms beyond." },
    { "name": "Senior Comms Officer",             "canonical": "Integration Senior Consultant - India",   "description": "Lays the relays of API, middleware, and event flows under the Chief Comms officer's plan." },
    { "name": "Comms Relay Technician",           "canonical": "Integration Consultant - India",          "description": "Learning the craft of integration — webhooks, batch, callouts, and Klingon-grade error handling." },
    { "name": "Chief Medical Officer",            "canonical": "QA Engineer",                             "description": "Tends the wounded systems — finds the maladies in the build before they reach the bridge." },
    { "name": "Federation Diplomatic Lead",       "canonical": "Marketing Practice Lead",                 "description": "Lifts the Federation banner — leads the entire marketing and outreach craft." },
    { "name": "Senior Diplomatic Officer",        "canonical": "Marketing Senior Consultant",             "description": "Strategist of first-contact campaigns — sounds the call to gather and convert." },
    { "name": "Diplomatic Attaché",               "canonical": "Marketing Consultant",                    "description": "Carries the campaign forward into the field — content, creative, and the daily away-mission." },
    { "name": "Stellar Cartographer",             "canonical": "Business Analyst",                        "description": "Records what is needed and what is promised — translates between the Captain's intent and the engineer's craft." },
    { "name": "Senior Engineering Officer — USA", "canonical": "Salesforce Senior Developer - USA",       "description": "Master engineer of the West Coast yards — leads the most complex platform builds." },
    { "name": "Cadet Consultant",                 "canonical": "Junior Salesforce Consultant - India",    "description": "Fresh out of the Academy — learns under a senior officer's wing on configuration and admin." }
  ],

